<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>SAS Donation Drive — Live Display</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #001e3c; min-height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

  .header { background: #003366; padding: 18px 36px; display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #0078D4; flex-shrink: 0; }
  .sas-logo { display: flex; align-items: center; gap: 14px; }
  .sas-logo-mark { background: #0078D4; color: #fff; font-size: 15px; font-weight: 700; padding: 6px 12px; border-radius: 6px; letter-spacing: 1.5px; }
  .sas-title { font-size: 20px; font-weight: 700; color: #fff; }
  .sas-subtitle { font-size: 13px; color: rgba(255,255,255,0.6); margin-top: 3px; }
  .header-right { display: flex; align-items: center; gap: 16px; }
  .live-dot { width: 8px; height: 8px; background: #22c55e; border-radius: 50%; animation: pulse 2s infinite; display: inline-block; margin-right: 6px; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.3)} }
  .live-label { font-size: 12px; color: rgba(255,255,255,0.7); display: flex; align-items: center; }
  .date-badge { background: rgba(255,255,255,0.1); color: #fff; font-size: 13px; padding: 6px 14px; border-radius: 20px; }

  .stats-bar { background: #002244; padding: 14px 36px; display: flex; gap: 0; border-bottom: 1px solid rgba(255,255,255,0.08); flex-shrink: 0; }
  .stat-pill { flex: 1; text-align: center; border-right: 1px solid rgba(255,255,255,0.1); }
  .stat-pill:last-child { border-right: none; }
  .stat-pill-label { font-size: 11px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 3px; }
  .stat-pill-value { font-size: 28px; font-weight: 700; color: #fff; }

  .main { flex: 1; display: grid; grid-template-columns: 1fr 220px; gap: 0; overflow: hidden; }

  .content-panel { padding: 28px 32px 24px; overflow: hidden; position: relative; }

  .view { position: absolute; inset: 28px 32px 24px; transition: opacity 0.6s ease, transform 0.6s ease; }
  .view.hidden { opacity: 0; pointer-events: none; transform: translateY(12px); }
  .view.visible { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .view-title { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between; }
  .tab-indicator { display: flex; gap: 6px; align-items: center; }
  .tab-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.2); }
  .tab-dot.active { background: #0078D4; }

  table { width: 100%; border-collapse: collapse; }
  .lb-header th { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; padding: 0 12px 10px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .lb-body td { padding: 13px 12px; font-size: 14px; border-bottom: 0.5px solid rgba(255,255,255,0.06); color: #e2e8f0; vertical-align: middle; }
  .lb-body tr:last-child td { border-bottom: none; }

  .rank-badge { display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 50%; font-size: 12px; font-weight: 700; }
  .rank-1 { background: #FFD700; color: #3d2600; }
  .rank-2 { background: #C0C0C0; color: #333; }
  .rank-3 { background: #CD7F32; color: #2a1400; }
  .rank-other { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.5); }

  .item-tag { display: inline-block; background: rgba(0,120,212,0.25); color: #93c5fd; font-size: 11px; padding: 2px 8px; border-radius: 10px; margin: 1px 2px 1px 0; }
  .bar-wrap { background: rgba(255,255,255,0.08); border-radius: 20px; height: 6px; overflow: hidden; margin-top: 4px; }
  .bar-fill { height: 6px; border-radius: 20px; background: #0078D4; }
  .team-name { font-weight: 600; color: #fff; font-size: 15px; }
  .qty-big { font-size: 18px; font-weight: 700; color: #60a5fa; }

  .log-header th { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; padding: 0 12px 10px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.08); }
  .log-body td { padding: 12px 12px; font-size: 13px; border-bottom: 0.5px solid rgba(255,255,255,0.06); color: #cbd5e1; vertical-align: middle; }
  .log-body tr:last-child td { border-bottom: none; }

  .countdown-bar { height: 3px; background: rgba(255,255,255,0.08); position: relative; flex-shrink: 0; }
  .countdown-fill { height: 3px; background: #0078D4; width: 100%; transition: width 0.1s linear; }

  .therm-panel { background: rgba(0,0,0,0.2); border-left: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 28px 20px; gap: 16px; flex-shrink: 0; }
  .therm-goal-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.5px; }
  .therm-pct-big { font-size: 36px; font-weight: 700; color: #fff; }
  .therm-outer { position: relative; width: 56px; height: 260px; }
  .therm-tube { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 34px; height: 228px; background: rgba(255,255,255,0.06); border-radius: 17px; border: 1.5px solid rgba(255,255,255,0.15); overflow: hidden; }
  .therm-fill { position: absolute; bottom: 0; left: 0; right: 0; background: #0078D4; transition: height 1s ease; }
  .therm-bulb { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 52px; height: 52px; border-radius: 50%; background: #0078D4; border: 2px solid #005fa3; }
  .t25 { position: absolute; top: 170px; right: -20px; font-size: 9px; color: rgba(255,255,255,0.35); }
  .t50 { position: absolute; top: 110px; right: -20px; font-size: 9px; color: rgba(255,255,255,0.35); }
  .t75 { position: absolute; top: 50px; right: -20px; font-size: 9px; color: rgba(255,255,255,0.35); }
  .tl25 { position: absolute; top: 170px; right: 17px; width: 6px; height: 1px; background: rgba(255,255,255,0.2); }
  .tl50 { position: absolute; top: 110px; right: 17px; width: 6px; height: 1px; background: rgba(255,255,255,0.2); }
  .tl75 { position: absolute; top: 50px; right: 17px; width: 6px; height: 1px; background: rgba(255,255,255,0.2); }
  .therm-count { font-size: 15px; font-weight: 600; color: #fff; text-align: center; }
  .therm-count-sub { font-size: 11px; color: rgba(255,255,255,0.45); text-align: center; }

  .empty-state { text-align: center; padding: 40px; color: rgba(255,255,255,0.3); font-size: 14px; }
</style>
</head>
<body>

<div class="header">
  <div class="sas-logo">
    <img src="data:image/png;base64," style="height:44px;width:auto;" alt="SAS logo" />
    <div>
      <div class="sas-title">Data for Good — Donation Drive</div>
      <div class="sas-subtitle">Boys &amp; Girls Club of Wake &amp; Johnston Counties &middot; June 17 – July 1</div>
    </div>
  </div>
  <div class="header-right">
    <span class="live-label"><span class="live-dot"></span>Live</span>
    <span class="date-badge" id="live-date"></span>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-pill"><div class="stat-pill-label">Total raised</div><div class="stat-pill-value" id="total-items">$0</div></div>
  <div class="stat-pill"><div class="stat-pill-label">Teams participating</div><div class="stat-pill-value" id="total-teams">0</div></div>
  <div class="stat-pill"><div class="stat-pill-label">Days remaining</div><div class="stat-pill-value" id="days-left">—</div></div>
  <div class="stat-pill"><div class="stat-pill-label">Goal</div><div class="stat-pill-value">$5,000</div></div>
</div>

<div class="main">
  <div class="content-panel">

    <div class="view visible" id="view-leaderboard">
      <div class="view-title">
        <span><i class="ti ti-trophy" style="vertical-align:-2px;margin-right:8px;color:#FFD700"></i>Team leaderboard</span>
        <div class="tab-indicator">
          <div class="tab-dot active" id="dot-0"></div>
          <div class="tab-dot" id="dot-1"></div>
        </div>
      </div>
      <table>
        <thead class="lb-header"><tr><th style="width:44px">#</th><th>Team</th><th>Raised</th><th>Categories</th><th style="width:140px">Progress</th></tr></thead>
        <tbody class="lb-body" id="leaderboard-body"></tbody>
      </table>
    </div>

    <div class="view hidden" id="view-log">
      <div class="view-title">
        <span><i class="ti ti-list" style="vertical-align:-2px;margin-right:8px;color:#60a5fa"></i>Recent donations</span>
        <div class="tab-indicator">
          <div class="tab-dot" id="dot-2"></div>
          <div class="tab-dot active" id="dot-3"></div>
        </div>
      </div>
      <table>
        <thead class="log-header"><tr><th>Date</th><th>Team</th><th>Donator</th><th>Item</th><th>Qty</th><th>Price</th><th>Note</th></tr></thead>
        <tbody class="log-body" id="log-body"></tbody>
      </table>
    </div>

  </div>

  <div class="therm-panel">
    <div class="therm-goal-label">Goal: $5,000</div>
    <div class="therm-pct-big" id="therm-pct">0%</div>
    <div class="therm-outer">
      <div class="therm-tube"><div class="therm-fill" id="therm-fill" style="height:0%"></div></div>
      <div class="therm-bulb"></div>
      <span class="tl25"></span><span class="t25">25%</span>
      <span class="tl50"></span><span class="t50">50%</span>
      <span class="tl75"></span><span class="t75">75%</span>
    </div>
    <div class="therm-count" id="therm-count">$0 / $5,000</div>
    <div class="therm-count-sub">raised</div>
  </div>
</div>

<div class="countdown-bar"><div class="countdown-fill" id="countdown-fill"></div></div>

<script>
const GOAL = 5000;
const ROTATE_MS = 30000;

function getEntries() {
  try { const s = localStorage.getItem('sas_donations'); return s ? JSON.parse(s) : []; } catch(e) { return []; }
}

function fmt(d) { return new Date(d+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric'}); }
function daysLeft() { const diff = Math.ceil((new Date('2026-07-01') - new Date()) / 86400000); return diff > 0 ? diff : 0; }

function render() {
  const entries = getEntries();
  const total = entries.reduce((s,e)=>s+(e.price||0),0);
  const teams = [...new Set(entries.map(e=>e.team))];
  document.getElementById('total-items').textContent = '$'+total.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
  document.getElementById('total-teams').textContent = teams.length;
  document.getElementById('days-left').textContent = daysLeft();
  const pct = Math.min(100, Math.round((total/GOAL)*100));
  document.getElementById('therm-pct').textContent = pct+'%';
  document.getElementById('therm-fill').style.height = pct+'%';
  document.getElementById('therm-count').textContent = '$'+total.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})+' / $5,000';

  const teamMap = {};
  entries.forEach(e=>{ if(!teamMap[e.team]) teamMap[e.team]={total:0,cats:new Set()}; teamMap[e.team].total+=(e.price||0); teamMap[e.team].cats.add(e.item); });
  const sorted = Object.entries(teamMap).sort((a,b)=>b[1].total-a[1].total);
  const maxQty = sorted.length ? sorted[0][1].total : 1;

  document.getElementById('leaderboard-body').innerHTML = sorted.length === 0
    ? '<tr><td colspan="5" class="empty-state">No donations logged yet!</td></tr>'
    : sorted.map(([team,data],i)=>{
        const rc = i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other';
        const cats = [...data.cats].map(c=>`<span class="item-tag">${c}</span>`).join('');
        return `<tr><td><span class="rank-badge ${rc}">${i+1}</span></td><td class="team-name">${team}</td><td><span class="qty-big">$${data.total.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}</span></td><td>${cats}</td><td><div class="bar-wrap"><div class="bar-fill" style="width:${Math.round((data.total/maxQty)*100)}%"></div></div></td></tr>`;
      }).join('');

  const sorted2 = [...entries].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,10);
  document.getElementById('log-body').innerHTML = sorted2.length === 0
    ? '<tr><td colspan="5" class="empty-state">No entries yet.</td></tr>'
    : sorted2.map(e=>`<tr><td style="color:rgba(255,255,255,0.5)">${fmt(e.date)}</td><td style="font-weight:600;color:#fff">${e.team}</td><td style="color:rgba(255,255,255,0.7)">${e.donator||'—'}</td><td><span class="item-tag">${e.item}</span></td><td style="color:rgba(255,255,255,0.7)">${e.qty}</td><td style="font-weight:700;color:#60a5fa">${e.price?'$'+Number(e.price).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}):'—'}</td><td style="color:rgba(255,255,255,0.45);font-size:12px">${e.note||'—'}</td></tr>`).join('');
}

let currentView = 0;
let startTime = Date.now();

function switchView() {
  const lb = document.getElementById('view-leaderboard');
  const lg = document.getElementById('view-log');
  currentView = currentView === 0 ? 1 : 0;
  if (currentView === 0) {
    lg.classList.remove('visible'); lg.classList.add('hidden');
    lb.classList.remove('hidden'); lb.classList.add('visible');
    document.getElementById('dot-0').classList.add('active'); document.getElementById('dot-1').classList.remove('active');
    document.getElementById('dot-2').classList.remove('active'); document.getElementById('dot-3').classList.add('active');
  } else {
    lb.classList.remove('visible'); lb.classList.add('hidden');
    lg.classList.remove('hidden'); lg.classList.add('visible');
    document.getElementById('dot-0').classList.remove('active'); document.getElementById('dot-1').classList.add('active');
    document.getElementById('dot-2').classList.add('active'); document.getElementById('dot-3').classList.remove('active');
  }
  startTime = Date.now();
  render();
}

function updateCountdown() {
  const elapsed = Date.now() - startTime;
  const remaining = Math.max(0, ROTATE_MS - elapsed);
  const pct = (remaining / ROTATE_MS) * 100;
  document.getElementById('countdown-fill').style.width = pct + '%';
}

setInterval(switchView, ROTATE_MS);
setInterval(render, 10000);
setInterval(updateCountdown, 100);

document.getElementById('live-date').textContent = new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
render();
<script>

async function loadData() {

const response =
await fetch("data.json");

const data =
await response.json();

console.log(data);

/* TOTAL */

const total =
document.getElementById("total");

if (total)
total.innerText =
data.total;


/* THERMOMETER */

const fill =
document.getElementById("thermFill");

if (fill)
fill.style.height =
(data.stats.progress || 0)
+ "%";

}

loadData();

/* refresh every 2 sec */

setInterval(
loadData,
2000
);

</script>
</body>
</html>
